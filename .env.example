# SportVenue — Database Configuration
#
# Driver: mysql | sqlite
# - mysql: requires MySQL server running
# - sqlite: zero-config, runs anywhere (including Wasmer)

DB_DRIVER=mysql

# MySQL settings (used when DB_DRIVER=mysql)
DB_MYSQL_HOST=127.0.0.1
DB_MYSQL_PORT=3306
DB_MYSQL_NAME=pemesanan_lapangan
DB_MYSQL_USER=root
DB_MYSQL_PASS=

# SQLite settings (used when DB_DRIVER=sqlite)
DB_SQLITE_PATH=database/data.db
